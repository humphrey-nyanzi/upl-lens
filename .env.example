# UPL Lens environment variables
#
# Copy this file to `.env` and fill in the values for your local machine.
# The loader, migration runner, and future API code all read from the same
# Postgres settings.

# PostgreSQL connection settings
#
# For normal local development, use your local Postgres user. For notebook-only
# research, prefer a read-only role such as `upl_research_reader` when available.
# For scheduled GitHub Actions refreshes, prefer a least-privilege loader role
# such as `upl_actions_loader` instead of a Supabase owner/admin credential.
# For Supabase pooler connections, the GitHub secret may need the project
# suffix, for example `upl_actions_loader.<project-ref>`.
POSTGRES_HOST=hostname
POSTGRES_PORT=hostport
POSTGRES_DB=database_name
POSTGRES_USER=your-postgres-username
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_SSLMODE=prefer

# FastAPI CORS settings
#
# CORS controls which browser-based frontends are allowed to call the API.
# Keep the local Vite origins for development. When deployed, add the hosted
# frontend origin too, separated by commas.
#
# Example:
# ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,https://your-frontend.pages.dev
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
